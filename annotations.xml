<?xml version="1.0" encoding="UTF-8"?>
<!--
  LEC Student Search — Site List
  ================================
  To add a site: copy any <Annotation> block and change the "about" URL.
  Labels determine which tab a site appears under:
    jewish_texts   → Jewish Texts tab
    chasidus       → Chasidus tab
    halacha        → Halacha tab
    hebrew         → Hebrew tab
    math           → Math tab
    science        → Science tab
    history        → History tab
    reference      → Reference tab
  A site can have multiple labels (appears in multiple tabs).
  _include_ must always be present — it's what allows the site in at all.
-->
<Annotations>

  <!-- ============================================================ -->
  <!-- JEWISH TEXTS — Primary Hebrew/Torah resources                 -->
  <!-- ============================================================ -->
  <Annotation about="sefaria.org/*">
    <Label name="_include_"/><Label name="jewish_texts"/><Label name="hebrew"/>
